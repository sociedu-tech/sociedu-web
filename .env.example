# Public URL of this Next.js app (OAuth callbacks, links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Spring Boot API (browser — must be NEXT_PUBLIC_*)
NEXT_PUBLIC_API_BASE_URL=http://localhost:9999

# Optional: Gemini (server-side only if used in API routes)
GEMINI_API_KEY=

# Đặt thành false hoặc bỏ để dùng Backend Data thật trong quá trình phát triển 
NEXT_PUBLIC_ADMIN_PREVIEW_DATA=true
